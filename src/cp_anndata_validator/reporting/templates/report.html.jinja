<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>cp-anndata-validator report: {{ report.input_file.path }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Roboto, sans-serif; margin: 2rem; color: #1a1a1a; }
  h1 { font-size: 1.4rem; margin-bottom: 0.25rem; }
  .meta { color: #444; margin-bottom: 1.5rem; line-height: 1.5; }
  .status { display: inline-block; padding: 0.15rem 0.6rem; border-radius: 4px; font-weight: 600; }
  .status-pass { background: #e6f4ea; color: #1e7e34; }
  .status-fail { background: #fdecea; color: #b3261e; }
  table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
  th, td { border: 1px solid #ddd; padding: 0.5rem; text-align: left; vertical-align: top; font-size: 0.85rem; }
  th { background: #f5f5f5; }
  .sev-error { color: #b3261e; font-weight: 600; }
  .sev-warning { color: #a15c00; font-weight: 600; }
  .sev-information { color: #0b5fa5; font-weight: 600; }
  .counts { margin-top: 1rem; }
  .no-issues { color: #1e7e34; font-weight: 600; }
</style>
</head>
<body>
  <h1>cp-anndata-validator report</h1>
  <div class="meta">
    <div>Package version: {{ report.package_version }}</div>
    <div>
      Input file: {{ report.input_file.path }}
      ({{ report.input_file.format }}, {{ "backed" if report.input_file.backed else "in-memory" }},
      {{ report.input_file.size_bytes }} bytes)
    </div>
    <div>Schema: {{ report.schema_id }} v{{ report.schema_version }}</div>
    <div>
      Profile level: effective={{ report.profile_level.effective.value if report.profile_level.effective else "unknown" }},
      declared={{ report.profile_level.declared.value if report.profile_level.declared else "none" }},
      detected={{ report.profile_level.detected.value if report.profile_level.detected else "none" }}
    </div>
    <div>Executed at: {{ report.executed_at.isoformat() }}</div>
    <div>Status: <span class="status status-{{ report.status }}">{{ report.status.upper() }}</span></div>
  </div>

  {% if report.issues %}
  <table>
    <thead>
      <tr>
        <th>Severity</th>
        <th>Code</th>
        <th>Category</th>
        <th>Location</th>
        <th>Message</th>
        <th>Evidence</th>
        <th>Remediation</th>
        <th>Check</th>
      </tr>
    </thead>
    <tbody>
      {% for issue in report.issues %}
      <tr>
        <td class="sev-{{ issue.severity.value }}">{{ issue.severity.value }}</td>
        <td>{{ issue.code }}</td>
        <td>{{ issue.category.value }}</td>
        <td>{{ issue.location }}</td>
        <td>{{ issue.message }}</td>
        <td>{{ issue.evidence or "" }}</td>
        <td>{{ issue.remediation }}</td>
        <td>{{ issue.check_name }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="no-issues">No issues found.</p>
  {% endif %}

  <div class="counts">
    <strong>Counts ({{ report.issues|length }} total):</strong>
    {% for severity, count in report.counts.by_severity.items() %}{{ severity.value }}={{ count }}{{ ", " if not loop.last else "" }}{% endfor %}
  </div>
</body>
</html>
